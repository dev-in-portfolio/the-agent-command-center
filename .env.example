# Supabase public/project metadata
SUPABASE_PROJECT_REF=mobvzrkcsfbumgbwvkcp
SUPABASE_URL=https://mobvzrkcsfbumgbwvkcp.supabase.co

# Supabase client/public key.
# Real value belongs in Netlify env or ignored local env.
SUPABASE_ANON_KEY=

# Server-only Supabase secret/service key.
# Never expose to browser. Never commit real value.
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct database password.
# Never commit real value.
SUPABASE_DB_PASSWORD=

# Optional direct database URL.
# Never commit real value.
DATABASE_URL=

# Feature gates. Default disabled.
MVP_ENABLE_SUPABASE_REQUEST_API=false
MVP_ENABLE_REQUEST_API_WRITES=false
MVP_ENABLE_SUPABASE_AUTH=false

