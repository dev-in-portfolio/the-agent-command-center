{
  "storage_readiness_model": {
    "storage_foundation_status": "READY_FOR_FOUNDATION_REVIEW_ONLY",
    "durable_storage_configured": false,
    "write_endpoint_enabled": false,
    "persistence_verified": false,
    "env_required": true,
    "secrets_required": true,
    "current_mode": "STORAGE_FOUNDATION_ONLY",
    "current_recommendation": [
      "STORAGE_CONTRACT_READY",
      "DURABLE_STORAGE_NOT_CONFIGURED",
      "NOT_READY_FOR_REQUEST_PERSISTENCE",
      "NOT_READY_FOR_REAL_AUTOMATION"
    ]
  },
  "request_draft_schema": {
    "type": "object",
    "required": [
      "request_id",
      "title",
      "intent",
      "scope",
      "requested_action_type"
    ],
    "properties": {
      "request_id": {
        "type": "string",
        "pattern": "^REQ-DEMO-\\d{8}-\\d{6}$"
      },
      "created_by": {
        "type": "string"
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time"
      },
      "title": {
        "type": "string",
        "minLength": 5
      },
      "intent": {
        "type": "string",
        "minLength": 10
      },
      "scope": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "source_phase": {
        "type": "string",
        "default": "plus2b"
      },
      "risk_classification": {
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ]
      },
      "requested_action_type": {
        "type": "string"
      },
      "current_state": {
        "type": "string",
        "default": "draft"
      },
      "approval_required": {
        "type": "boolean",
        "default": true
      },
      "dry_run_required": {
        "type": "boolean",
        "default": true
      },
      "no_go_flags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "notes": {
        "type": "string"
      }
    }
  },
  "request_record_schema": {
    "type": "object",
    "required": [
      "request_id",
      "current_state",
      "storage_status"
    ],
    "properties": {
      "request_id": {
        "type": "string"
      },
      "created_by": {
        "type": "string"
      },
      "created_at": {
        "type": "string"
      },
      "updated_at": {
        "type": "string"
      },
      "current_state": {
        "enum": [
          "draft",
          "packet_generated",
          "under_review",
          "review_approved_for_planning",
          "handoff_composed",
          "runbook_generated",
          "blocked_by_no_go",
          "storage_not_configured",
          "archived"
        ]
      },
      "packet_reference": {
        "type": "string"
      },
      "review_reference": {
        "type": "string"
      },
      "handoff_reference": {
        "type": "string"
      },
      "runbook_reference": {
        "type": "string"
      },
      "auth_context": {
        "type": "object"
      },
      "audit_event_ids": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "storage_status": {
        "type": "string"
      }
    }
  },
  "request_lifecycle_state_model": {
    "allowed_states": [
      "draft",
      "packet_generated",
      "under_review",
      "review_approved_for_planning",
      "handoff_composed",
      "runbook_generated",
      "blocked_by_no_go",
      "storage_not_configured",
      "archived"
    ],
    "forbidden_states": [
      "queued_for_execution",
      "executing",
      "executed",
      "mutating_external_system",
      "deployed",
      "merged",
      "pushed",
      "pr_created"
    ]
  },
  "storage_adapter_contract": {
    "methods": [
      "get_storage_status()",
      "validate_request_draft(payload)",
      "create_request_draft(payload)",
      "get_request_draft(request_id)",
      "list_request_drafts()",
      "update_request_draft(request_id, payload)",
      "archive_request_draft(request_id)"
    ],
    "current_behavior": "STORAGE_NOT_CONFIGURED"
  },
  "request_id_strategy": "REQ-DEMO-YYYYMMDD-HHMMSS",
  "future_storage_dependencies": [
    {
      "item": "approved durable storage provider",
      "status": "missing"
    },
    {
      "item": "server-side auth binding",
      "status": "missing"
    },
    {
      "item": "audit log dependency",
      "status": "missing"
    },
    {
      "item": "approval record dependency",
      "status": "missing"
    },
    {
      "item": "migration plan",
      "status": "missing"
    },
    {
      "item": "backup/restore plan",
      "status": "missing"
    },
    {
      "item": "retention policy",
      "status": "missing"
    }
  ]
}