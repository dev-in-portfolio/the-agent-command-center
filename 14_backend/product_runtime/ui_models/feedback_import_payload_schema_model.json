{
  "model_id": "feedback-import-payload-schema-model",
  "model_version": "1.0",
  "allowed_fields": [
    "reviewer_persona", "reviewer_context", "clarity_rating", 
    "confidence_rating", "demo_readiness_rating", "pitchability_rating",
    "strongest_parts", "confusing_parts", "blockers", "trust_concerns",
    "suggested_next_step", "would_share", "raw_packet", "source"
  ],
  "required_fields": [
    "reviewer_persona"
  ],
  "blocked_dangerous_fields": [
    "id", "owner_user_id", "actor_id", "user_id", "service_role", 
    "token", "secret", "api_key", "command", "shell", "script",
    "execute", "approve", "deploy", "merge", "push", "automation"
  ],
  "rating_validation": "integer 1-5",
  "ownership_fields_blocked_from_client": true,
  "owner_user_id_server_derived_only": true,
  "raw_packet_sanitized": true
}
